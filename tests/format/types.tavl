// =============================================================================
//  tavl — распознаваемые типы данных
//  Каждая строка формата: identifier = value  (оператор '=' связывает имя и значение)
//  Запятая ИЛИ перевод строки завершают строку. Файл — неявный кортеж.
// =============================================================================

// null — явное отсутствие значения (также NULL)
nothing = null

// boolean — true | false (также TRUE | FALSE)
flag_on  = true
flag_off = false

// целые числа: десятичные (со знаком), hex (0x), octal (0o), binary (0b)
answer  = 42
below   = -7
mask    = 0xFF
perms   = 0o755
flags   = 0b1010

// числа с плавающей точкой: обычные, экспонента, ведущая точка, спец-значения
pi       = 3.14159
avogadro = 6.022e23
half     = .5
infinity = inf
not_num  = nan

// строки:
//   '...' — мультистрока с минимальным escape (только \' и \\), всё прочее как есть
//   "..." — стандартные escape (\n \t \r ...) + юникод \uXXXX / \UXXXXXXXX
raw_path = 'C:\Users\name'
message  = "line one\nline two\ttabbed"
emoji    = "heart ❤ grin \U0001F600"

// datetime в формате ISO; разделитель даты/времени — 'T' или '_'; опц. дробь и пояс
date_only = 2026-06-14
stamp_t   = 2026-06-14T12:30:00
stamp_u   = 2026-06-14_12:30:00.500Z
stamp_tz  = 2026-06-14T12:30:00+05:00

// идентификатор как значение: [A-Za-z_][A-Za-z0-9_.]* (допускается точка)
reference = some.nested.field
