// =============================================================================
//  tavl — блоки и режимы разбора строк
//  { } объект   — первый не-оператор = идентификатор строки, далее оператор и данные
//  ( ) кортеж   — гибрид: есть id+оператор -> как объект, иначе -> как массив
//  [ ] массив   — все токены трактуются как данные
//  Разделители строк внутри блока: запятая ИЛИ перевод строки.
// =============================================================================

// объект: пары идентификатор = значение
window = {
  width  = 1920
  height = 1080
  title  = "main"
}

// массив: просто последовательность значений (через запятую или перевод строки)
palette = [red, green, blue]
sizes   = [
  16
  32
  64
]

// "inline" запись: данные строки можно писать и БЕЗ скобок, прямо после оператора —
// это та же последовательность значений, просто без обрамляющего блока
sizes_inline = 16 32 64
rgb_inline   = 255 128 0

// идентификатор строки — ЛЮБОЙ токен, кроме скобок (не обязательно имя-идентификатор):
42         = answer        // число как идентификатор строки
"with spc" = quoted_key    // строка как идентификатор
2026-01-01 = new_year      // дата как идентификатор
true       = yes           // boolean как идентификатор

// кортеж как объект (именованные поля)
point = (x = 10, y = 20)

// кортеж как массив (позиционные значения)
color = (255, 128, 0, 255)

// вложенность блоков произвольной глубины
scene = {
  camera = (0.0, 1.5, -3.0)
  objects = [
    { name = "cube",   pos = (0, 0, 0) },
    { name = "sphere", pos = (2, 0, 0) }
  ]
}
