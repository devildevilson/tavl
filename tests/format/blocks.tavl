// =============================================================================
//  tavl — blocks and row parsing modes
//  { } object  — first non-operator = row identifier, then operator and data
//  ( ) tuple   — hybrid: has id+operator -> acts as object, otherwise -> as array
//  [ ] array   — every token is treated as data
//  Row separators inside a block: a comma OR a newline.
// =============================================================================

// object: identifier = value pairs
window = {
  width  = 1920
  height = 1080
  title  = "main"
}

// array: just a sequence of values (separated by commas or newlines)
palette = [red, green, blue]
sizes   = [
  16
  32
  64
]

// "inline" form: a row's data may also be written WITHOUT brackets, right after
// the operator — it is the same sequence of values, just without an enclosing block
sizes_inline = 16 32 64
rgb_inline   = 255 128 0

// the row identifier is ANY token except brackets (not necessarily a name-identifier):
42         = answer        // number as a row identifier
"with spc" = quoted_key    // string as an identifier
2026-01-01 = new_year      // date as an identifier
true       = yes           // boolean as an identifier

// tuple as an object (named fields)
point = (x = 10, y = 20)

// tuple as an array (positional values)
color = (255, 128, 0, 255)

// blocks nest to arbitrary depth
scene = {
  camera = (0.0, 1.5, -3.0)
  objects = [
    { name = "cube",   pos = (0, 0, 0) },
    { name = "sphere", pos = (2, 0, 0) }
  ]
}
