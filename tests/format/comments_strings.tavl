// =============================================================================
//  tavl — comments and strings
// =============================================================================

// this is a single-line comment (// to the end of the line)

/* and this is a block
   comment that spans
   several lines */

greeting = "hello\nworld"          // double quotes: \n -> newline when read

raw = 'C:\path\to\file'            // single quotes: \ does not escape (except \' and \)

multiline = "first line
second line"                        // strings are multiline: a real newline inside "" is allowed

unicode = "\u2764 \U0001F600"      // \u — a BMP code point, \U — an astral one (4 bytes)

quoted_id = "has spaces"           // if a string is not a valid identifier — quotes are required
plain_id  = no_spaces_here         // otherwise quotes can be omitted

// two rows with IDENTICAL content, differing only in identifier and quote type.
// double: all of these sequences ARE RECOGNIZED as escapes (\n -> newline, \uXXXX -> unicode).
// single: escapes NOTHING (except \' and \) — the same sequences stay LITERAL.
dq = "\n \r \t \a \b \f \v \\ \" \u2764 \U0001F600"
sq = '\n \r \t \a \b \f \v \\ \" \u2764 \U0001F600'
