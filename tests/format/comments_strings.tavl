// =============================================================================
//  tavl — комментарии и строки
// =============================================================================

// это однострочный комментарий (// до конца строки)

/* а это блочный
   комментарий, который
   занимает несколько строк */

greeting = "hello\nworld"          // двойные кавычки: \n -> перевод строки при чтении

raw = 'C:\path\to\file'            // одинарные: \ не экранирует (кроме \' и \)

multiline = "первая строка
вторая строка"                      // строки многострочны: реальный перевод внутри "" допустим

unicode = "\u2764 \U0001F600"      // \u — кодовая точка BMP, \U — астральная (4 байта)

quoted_id = "has spaces"           // если строка не валидный идентификатор — нужны кавычки
plain_id  = no_spaces_here         // а так можно без кавычек

// две строки с ОДИНАКОВЫМ содержимым, отличаются только идентификатором и типом кавычек.
// double: все эти последовательности РАСПОЗНАЮТСЯ как escape (\n -> перевод строки, \uXXXX -> юникод).
// single: НЕ экранирует ничего (кроме \' и \) — те же последовательности останутся ЛИТЕРАЛЬНЫМИ.
dq = "\n \r \t \a \b \f \v \\ \" \u2764 \U0001F600"
sq = '\n \r \t \a \b \f \v \\ \" \u2764 \U0001F600'
